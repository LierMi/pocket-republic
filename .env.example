# Optional overrides for the local Kite Passport bridge.
# Authentication is managed by the official kpass CLI in .kpass/ or ~/.kpass.

PORT=5180
KITE_KPASS_PATH=
KITE_KSEARCH_PATH=

# Comma-separated HTTPS hosts that the bridge may call through x402.
# StableCrypto (Kite catalog) and the Kite test service are allowed by default.
KITE_ALLOWED_HOSTS=stablecrypto.dev,x402.dev.gokite.ai

# Gonka（赞助方，Anthropic Messages 兼容）为国民议会提供真实 AI 推理。
# 密钥只放本地 .env（已被 .gitignore 排除），由本地桥接读取，绝不进入浏览器或 Vercel。
# 未配置时议会自动退回内置脚本发言。
GONKA_API_KEY=
GONKA_BASE_URL=https://api.gonkarouter.io/v1
GONKA_MODEL=moonshotai/Kimi-K2.6
